{
  "name": "valley-mas",
  "version": "1.0.0",
  "private": true,
  "description": "创作者口令空间 - 图片分享平台",
  "scripts": {
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=@valley/admin",
    "build": "turbo build",
    "build:admin": "turbo build --filter=@valley/admin",
    "init-repo": "turbo build -F '!./apps/*'  && pnpm install --frozen-lockfile",
    "lint": "turbo lint",
    "format": "turbo format",
    "check": "turbo check",
    "check:utf8": "powershell -ExecutionPolicy Bypass -File ./scripts/check-utf8.ps1",
    "clean": "turbo clean",
    "prepare": "lefthook install",
    "hooks:test": "lefthook run pre-commit",
    "classics:seed": "node ./scripts/classics-seed.js",
    "classics:import-fulltext": "node ./scripts/classics-import-fulltext.js"
  },
  "keywords": [
    "react",
    "monorepo",
    "turborepo"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "lefthook": "^2.1.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "tslib": "^2.8.1"
    }
  }
}
