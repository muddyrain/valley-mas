{
  "name": "@valley/world-sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude src/sim/scaleMeasurement.measure.test.ts --exclude src/sim/growthObservation.measure.test.ts --exclude src/sim/buildingSiteObservation.measure.test.ts",
    "measure:scale": "vitest run src/sim/scaleMeasurement.measure.test.ts --reporter=verbose",
    "observe:growth": "vitest run src/sim/growthObservation.measure.test.ts --reporter=verbose",
    "observe:building-sites": "vitest run src/sim/buildingSiteObservation.measure.test.ts --reporter=verbose",
    "test:watch": "vitest",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "6.3.5",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
