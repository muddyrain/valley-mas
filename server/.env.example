# env：development / production
ENV=development

# port
PORT=8080

# db-driver：postgres / mysql
DB_DRIVER=postgres

# PostgreSQL config
DB_SLOW_LOG_MS=2000
DB_AUTO_MIGRATE=false
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
DB_CONN_MAX_LIFETIME_MIN=30
DB_CONN_MAX_IDLE_TIME_MIN=10

# PostgreSQL / Supabase/neon
DB_DSN=postgresql://user:password@host:5432/dbname?sslmode=require

# DB config mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=valley

# JWT config
JWT_SECRET=your-jwt-secret-key
# Default is 10 years for app-style long login. Override with hours if needed.
JWT_EXPIRE_HOURS=87600

# TOS config
TOS_ACCESS_KEY=your_access_key
TOS_SECRET_KEY=your_secret_key
TOS_BUCKET=your_bucket_name
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing

# Valley AI Chat system prompt（仅影响主站通用聊天口吻）
AI_CHAT_SYSTEM_PROMPT=你是 Valley 的 AI 助手，请始终使用简体中文回答，并给出简洁、准确、可执行的建议。

# Shared ARK config
# 控制台：https://console.volcengine.com/ark
# 使用范围：
# - ARK_TEXT_MODEL：Valley AI Chat、Blog/Creator 文本 AI、Life Trace 文本 AI 的默认模型。
# - ARK_VISION_MODEL：Creator 图片标签/起名、Life Trace 通用图片分析、衣物识别；Pantry 拍照未配置 Gemini 时回退这里。
# - ARK_IMAGE_MODEL：Blog 封面生图、Life Trace Pantry 缩略图生图。
# - ARK_EMBEDDING_MODEL：AI 工作台知识库的文档向量化接入点；不回退到文本对话模型。
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_MODEL=ep-xxxxxxxxxx
# AI 工作台上下文副驾驶灰度；设为 false/0/off/no 时回退旧助手。
AI_WORKBENCH_COPILOT_ENABLED=true
ARK_VISION_MODEL=ep-xxxxxxxxxx
ARK_IMAGE_MODEL=ep-xxxxxxxxxx
ARK_EMBEDDING_MODEL=ep-xxxxxxxxxx
# 可选：逗号分隔的生图模型兜底列表，主模型能力不匹配时尝试。
ARK_IMAGE_MODEL_FALLBACK=

# Shared Gemini config
# 使用范围：Life Trace Pantry 拍照分析优先使用 Gemini 视觉模型；未配置 GEMINI_API_KEY 时回退 ARK_VISION_MODEL/ARK_TEXT_MODEL。
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-2.5-flash
# 可选：auto 优先 Gemini，ark 强制走 ARK，gemini 强制走 Gemini。
LIFE_TRACE_PANTRY_PHOTO_AI_PROVIDER=auto
# 可选：Life Trace Pantry 拍照分析超时秒数；不填时默认 30 秒。
LIFE_TRACE_PANTRY_PHOTO_AI_TIMEOUT_SECONDS=30

# Life Trace text AI override（可选，OpenAI-compatible）
# 配置后，Life Trace 的今日建议、周报、AI chat、Inbox 整理、菜谱、书影音补全和穿搭建议会优先使用这里。
# 不配置时回退到上方 ARK_TEXT_MODEL。
LIFE_TRACE_AI_API_KEY=
LIFE_TRACE_AI_BASE_URL=
LIFE_TRACE_AI_MODEL=gpt-5.4
LIFE_TRACE_AI_TIMEOUT_SECONDS=30

# Life Trace 生活助理 Agent 灰度开关。
# true / 1 / yes / on 时走 internal/ai/agent 手写 tool loop（可自主调 5 个 tool）；
# 其他值一律回退到旧的结构化 tool-call 单次调用 + fallback 路径。
# 默认关闭，本地自测通过后再打开。
LIFE_TRACE_ASSISTANT_USE_AGENT=false

# Life Trace weather config（和风天气 QWeather）
QWEATHER_API_KEY=
# 从和风天气控制台复制项目的 API Host，例如 https://xxxx.qweatherapi.com
# 旧公共域名 devapi.qweather.com / geoapi.qweather.com 已不再适合作为默认配置。
QWEATHER_API_HOST=
# 可选：不填时复用 QWEATHER_API_HOST。
QWEATHER_GEO_HOST=
QWEATHER_CACHE_TTL_MINUTES=30
QWEATHER_TIMEOUT_SECONDS=5
QWEATHER_REFRESH_COOLDOWN_SECONDS=300

# Life Trace transparent cover config（remove.bg）
# 当前透明封面使用 remove.bg API 做商品抠图；API key 只放服务端环境变量，不放前端。
REMOVE_BG_API_KEY=
REMOVE_BG_API_URL=https://api.remove.bg/v1.0/removebg
# preview 响应最快、适合库存封面；可按需要改为 auto/full。
REMOVE_BG_SIZE=preview

# Life Trace Web Push config
# Generate keys with: go test ./internal/lifetrace -run TestGenerateVAPIDKeys -v
WEB_PUSH_ENABLED=true
WEB_PUSH_WORKER_ENABLED=true
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.com
WEB_PUSH_CRON_SECRET=
WEB_PUSH_SCAN_INTERVAL_SECONDS=60
WEB_PUSH_REMINDER_WINDOW_MINUTES=10

# Life Trace holiday calendar sync
# {year} will be replaced by the target year. The built-in 2026 calendar is used as fallback.
HOLIDAY_SYNC_ENABLED=true
HOLIDAY_SYNC_API_URL_TEMPLATE=https://timor.tech/api/holiday/year/{year}
HOLIDAY_SYNC_INTERVAL_HOURS=168
HOLIDAY_SYNC_FUTURE_YEARS=1
HOLIDAY_SYNC_TIMEOUT_SECONDS=8

# Blog external cover images（选封面弹窗里的 Unsplash / Pexels Tab）
# Unsplash: https://unsplash.com/documentation#creating-a-developer-account
# Pexels:   https://www.pexels.com/api/new/
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
EXTERNAL_IMAGES_TIMEOUT_SECONDS=8

# AI Mind Arena config（脑内会议室）
# 只影响 apps/ai-mind-arena 对应后端，不影响 Life Trace 或 Valley AI Chat。
# provider: mock / openai-compatible / doubao
# 当真实模型配置缺失或上游失败时，会自动回退到 mock。
MIND_ARENA_AI_PROVIDER=mock
# Doubao 推荐：https://ark.cn-beijing.volces.com/api/v3
MIND_ARENA_AI_BASE_URL=https://api.openai.com/v1
MIND_ARENA_AI_API_KEY=
# 可选：不填时复用 ARK_TEXT_MODEL；只有脑内会议室需要单独模型时再配置。
# MIND_ARENA_AI_MODEL=gpt-4o-mini

# email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM_NAME=Valley
SMTP_FROM_ADDRESS=your_gmail@gmail.com

# Desktop OS Mail binding
# 32-byte secret for encrypting external mailbox tokens / authorization codes.
MAIL_SECRET_KEY=change-me-32-byte-mail-secret-key
MAIL_PUBLIC_BASE_URL=http://localhost:8080/api/v1
MAIL_FRONTEND_REDIRECT_URL=http://localhost:5177
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URL=http://localhost:8080/api/v1/user/mail/accounts/gmail/callback
