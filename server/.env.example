# 环境：development / production
ENV=development

# 服务端口
PORT=8080

# 数据库驱动：postgres / mysql（默认 postgres）
DB_DRIVER=postgres

# 慢 SQL 阈值（毫秒）
DB_SLOW_LOG_MS=100
DB_AUTO_MIGRATE=false

# 统一 DSN（推荐 PostgreSQL / Neon）
DB_DSN=postgresql://user:password@host:5432/dbname?sslmode=require

# MySQL（当 DB_DRIVER=mysql 且不使用 DB_DSN 时）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=valley

# JWT 配置
JWT_SECRET=your-jwt-secret-key

# 火山引擎 TOS 配置
TOS_ACCESS_KEY=your_access_key
TOS_SECRET_KEY=your_secret_key
TOS_BUCKET=your_bucket_name
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing

# TTS 配置
TTS_BASE_URL=http://127.0.0.1:7860
TTS_UPSTREAM_PATH=/synthesize
TTS_OUTPUT_DIR=./data/tts
TTS_TIMEOUT_SEC=120
TTS_API_KEY=

# AI Chat 配置（仅 Ollama）
AI_PROVIDER=ollama
AI_CHAT_SYSTEM_PROMPT=你是 Valley 的 AI 助手，请用简洁、准确、可执行的中文回答。
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
